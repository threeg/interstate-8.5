# Pristine .gitignore template — copied out to the project root as ./.gitignore by sfk-init
# (only when the repo has none of its own). Named without a leading dot on purpose so it does
# not act as a live .gitignore inside .sfk/templates/. sfk-init also ensures the
# .claude/settings.local.json line below is present even when a project brings its own .gitignore.

# --- OS cruft ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editors / IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace

# --- Environment / secrets ---
.env
.env.*
!.env.example
*.local

# --- Logs & temp ---
*.log
logs/
tmp/
.cache/

# --- Dependency / build artefacts (uncomment those your stack uses) ---
node_modules/
/web/themes/custom/*/node_modules/
dist/
build/
!web/themes/custom/*/css/build/
coverage/

# --- Playwright test artefacts ---
/tests/playwright/test-results/
/tests/playwright/playwright-report/
.phpunit.cache/
# .venv/
# __pycache__/
# *.pyc
# target/
# .pytest_cache/
# .mypy_cache/

# --- Drupal / Composer ---
/vendor/
/drush/Commands/contrib/
/web/core/
/web/libraries/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/sites/*/files/
/web/sites/*/private/
/web/sites/*/settings.local.php
/web/sites/*/settings.ddev.php
/web/sites/*/settings.lando.php
/web/sites/*/services.local.yml

# --- Lando ---
/.lando.local.yml

# --- Legacy v2 data (not committed — large; sourced from the v4 repo) ---
/legacy/

# --- Claude Code local state (keep .claude/skills tracked; ignore local settings) ---
.claude/settings.local.json
/.editorconfig
/.gitattributes